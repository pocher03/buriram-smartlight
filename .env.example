# ============================================================
# .env.example — ศูนย์บัญชาการโคมไฟถนนอัจฉริยะ เทศบาลเมืองบุรีรัมย์
# คัดลอกเป็น .env.local แล้วเติมค่าจริง (.env.local ถูก gitignore)
# 🔴 ห้ามใช้ NEXT_PUBLIC_ กับค่าลับ — ค่าลับทั้งหมดอยู่ฝั่ง Worker/Backend เท่านั้น
# ============================================================

# ---- Data source (mock | live) — สลับ Adapter ----
DATA_SOURCE=mock

# ---- RULR AIoT (ต้นทาง) — Worker/Backend เท่านั้น (Sprint 2) ----
RULR_BASE_URL=https://rulr-aiot.com
RULR_CLIENT_ID=
RULR_CLIENT_SECRET=
RULR_DIVISION_ID=1889
RULR_DOMAIN=IMPACT

# ---- OpenWeatherMap (สภาพอากาศเทศบาล) — Worker เท่านั้น (Sprint 2) ----
OPENWEATHER_API_KEY=
WEATHER_LAT=14.992892
WEATHER_LNG=103.113694

# ---- PostgreSQL (Prisma + docker-compose) ----
POSTGRES_USER=buriram
POSTGRES_PASSWORD=
POSTGRES_DB=buriram_smartlight
# ภายใน docker network ใช้ host = "postgres"; dev บนเครื่องใช้ localhost
DATABASE_URL=postgresql://buriram:CHANGEME@postgres:5432/buriram_smartlight?schema=public

# ---- Auth.js (NextAuth v5) — Sprint 3 ----
AUTH_SECRET=
AUTH_URL=https://monitor.jumboelec.co.th

# ---- Email (Resend) — ลืมรหัสผ่าน, Sprint 3 ----
RESEND_API_KEY=

# ---- Deploy / Caddy ----
APP_DOMAIN=monitor.jumboelec.co.th
# อีเมลสำหรับออก Let's Encrypt cert ผ่าน Caddy
CADDY_ACME_EMAIL=ops@jumboelec.co.th
