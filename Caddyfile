# ============================================================
# Caddyfile — Reverse proxy + Auto-HTTPS (Let's Encrypt)
# ตัวแปร {$APP_DOMAIN}, {$CADDY_ACME_EMAIL} มาจาก env_file (.env.local) ของ service caddy
# ============================================================

{
	email {$CADDY_ACME_EMAIL}
	# เปิดบรรทัดล่างเพื่อทดสอบด้วย staging cert (กัน rate-limit ตอน setup)
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$APP_DOMAIN} {
	encode zstd gzip

	# ส่งต่อไปยัง Next.js app ภายใน network (ชื่อ service = app)
	reverse_proxy app:3000

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
