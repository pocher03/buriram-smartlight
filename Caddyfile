# ============================================================
# Caddyfile — Reverse proxy + Auto-HTTPS (Let's Encrypt)
# ============================================================

{
	email {$CADDY_ACME_EMAIL}
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$APP_DOMAIN} {
	encode zstd gzip

	# ส่งต่อไปยัง Next.js app ภายใน network (ชื่อ service = app)
	reverse_proxy app:3000 {
		# ประทับ IP จริงของผู้เชื่อมต่อลง X-Real-IP
		# Caddy "เขียนทับ" ค่าที่ client ส่งมา → ปลอมไม่ได้ (Caddy เป็น edge ตรง ไม่มี CDN/LB คั่น)
		header_up X-Real-IP {http.request.remote.host}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}